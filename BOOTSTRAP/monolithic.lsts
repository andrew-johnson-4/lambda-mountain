let config-v1 = false;
let config-v0 = false;

let .skey(t: Token): String = intern(t.key);
type AST implements DefaultFormattable;

# constructor with a default argument

type alias AContext = List<(CString,AST)>;

type ParsePartial = PME{ term:AST , remainder:List<Token> };

type ApplyResult = { function-type:Type , return-type:Type };

type CompileMode = ModeTokenize | ModeParse | ModePreprocess | ModeTypecheck | ModeCompile;

type IsUsed = Used | Unused | Tail | Call { function-name: CString };
let .is-call(used: IsUsed): Bool = (
   match used {
      Call{} => true;
      _ => false;
   }
);
let .is-used(used: IsUsed): Bool = (
   match used {
      Used{} => true;
      _ => false;
   }
);
let .is-unused(used: IsUsed): Bool = (
   match used {
      Unused{} => true;
      _ => false;
   }
);
let .is-tail(used: IsUsed): Bool = (
   match used {
      Tail{} => true;
      _ => false;
   }
);
let .into(used: IsUsed, ty: Type<String>): String = (
   match used {
      Used{} => "Used";
      Unused{} => "Unused";
      Tail{} => "Tail";
      Call{} => "Call";
   }
);

type Macro = { lhs:AST, rhs:AST };
type MacroList zero MEOF = MEOF | MSeq{ k:OneOwnedData<MacroList>[], v:Macro };

let mk-location(): SourceLocation = (
   SourceLocation ( c"Unknown", 0, 0 )
);

let non-zero(loc: SourceLocation): Bool = (
   loc.line != 0
);

let $"||"(lloc: SourceLocation, rloc: SourceLocation): SourceLocation = (
   if non-zero(lloc) then lloc else rloc
);

let mk-token(s: CString): Token = (
   Token ( s, iuid(), mk-location() )
);

let mk-token(s: String): Token = (
   Token ( s.into(type(CString)), iuid(), s.location )
);


let $"+"(l: AST, r: AST): AST = (
   match l {
      Seq{seq=seq} => (match r {
         Seq{rseq=seq} => (
            for rs in rseq { l = l + rs; };
            l
         );
         _ => Seq(seq.push(r));
      });
      ASTEOF{} => (
         l = Seq(mk-vector(type(AST)));
         l + r
      );
   };
);

let substitute-uuids(ctx: AContext, term: AST): AST = (
   match term {
      App{left:Var{key:c"uuid"}, right:Var{x=key}} => (
         ctx.lookup(x,term)
      );
      Seq{seq=seq} => (
         let ret = mk-vector(type(AST), seq.length);
         for s in seq { ret = ret.push(substitute-uuids(ctx,s)) };
         Seq(ret)
      );
      Abs{lhs=lhs,rhs=rhs,tt=tt} => (
         Abs(close(substitute-uuids(ctx,lhs)), close(substitute-uuids(ctx,rhs)), tt)
      );
      App{is-cons=is-cons,left=left,right=right} => (
         App(is-cons,close(substitute-uuids(ctx,left)), close(substitute-uuids(ctx,right)))
      );
      Glb{key=key,val=val} => (
         Glb(key, close(substitute-uuids(ctx,val)))
      );
      _ => term;
   }
);

let .unique(term: AST): AST = (
   match term {
      Var{vkey=key, token=token} => Var(vkey, token.unique);
      Lit{lkey=key, token=token} => Lit(lkey, token.unique);
      Seq{seq=seq} => (
         let ret = mk-vector(type(AST), seq.length);
         for s in seq { ret = ret.push(s.unique) };
         Seq(ret)
      );
      App{is-cons=is-cons,left=left,right=right} => mk-cons-or-app(is-cons,left.unique,right.unique);
      Abs{lhs=lhs,rhs=rhs,tt=tt} => mk-abs(lhs.unique, rhs.unique, tt);
      Glb{gkey=key,val=val} => mk-glb(gkey, val.unique);
      _ => term;
   }
);

let .unroll-seq(t: AST): Vector<AST> = (
   match t {
      Seq{seq=seq} => seq;
      _ => mk-vector(type(AST));
   }
);

let var-name-if-var(t: AST): CString = (
   match t {
      Var{key=key} => key;
      _ => c"";
   }
);

let var-name-if-var-or-lit(t: AST): CString = (
   match t {
      Var{key1=key} => key1;
      Lit{key2=key} => key2;
      _ => c"";
   }
);

let lit-name-if-lit(t: AST): CString = (
   match t {
      Lit{key1=key} => key1;
      App{ left:Lit{key:c":"}, right:App{ left:Lit{key2=key}, right:AType{} } } => key2;
      _ => c"";
   }
);

let hint-if-hint(t: AST): Type = (
   match t {
      App{ left:Lit{key:c":"}, right:App{ right:AType{hint=tt} } } => hint;
      _ => ta;
   }
);

let .with-location-preserve(term: AST, loc: SourceLocation): AST = (
   match term {
      Var{key1=key,token=token} => Var(key1,with-location(token,loc));
      Lit{key2=key,token=token} => Lit(key2,with-location(token,loc));
      App{is-cons=is-cons,left=left,right=right} => mk-cons-or-app(is-cons,left.with-location-preserve(loc),right.with-location-preserve(loc));
      Seq{seq=seq} => (
         let ret = mk-vector(type(AST), seq.length);
         for s in seq { ret = ret.push(s.with-location-preserve(loc)) };
         Seq(ret)
      );
      Abs{lhs=lhs,rhs=rhs,tt=tt} => Abs(close(lhs.with-location-preserve(loc)),close(rhs.with-location-preserve(loc)),tt);
      Glb{key3=key,val=val} => Glb(with-location(key3,loc),close(val.with-location-preserve(loc)));
      _ => term;
   }
);

let .with-location(term: AST, loc: SourceLocation): AST = (
   match term {
      Var{key1=key,token=token} => Var(key1,with-location(token,loc));
      Lit{key2=key,token=token} => Lit(key2,with-location(token,loc));
      App{left=left,right=right} => App(close(left.with-location(loc)),close(right.with-location(loc)));
      Seq{seq=seq} => (
         let ret = mk-vector(type(AST), seq.length);
         for s in seq { ret = ret.push(s.with-location(loc)) };
         Seq(ret)
      );
      Abs{lhs=lhs,rhs=rhs,tt=tt} => Abs(close(lhs.with-location(loc)),close(rhs.with-location(loc)),tt);
      Glb{key3=key,val=val} => Glb(with-location(key3,loc),close(val.with-location(loc)));
      _ => term;
   }
);

let .without-location(term: AST): AST = (
   match term {
      Var{key1=key,token=token} => Var(key1,token.without-location);
      Lit{key2=key,token=token} => Lit(key2,token.without-location);
      App{is-cons=is-cons,left=left,right=right} => App(is-cons,close(left.without-location),close(right.without-location));
      Seq{seq=seq} => (
         let ret = mk-vector(type(AST), seq.length);
         for s in seq { ret = ret.push(s.without-location) };
         Seq(ret)
      );
      Abs{lhs=lhs,rhs=rhs,tt=tt} => Abs(close(lhs.without-location),close(rhs.without-location),tt);
      Glb{key3=key,val=val} => Glb(key3,close(val.without-location));
      _ => term;
   }
);

let bind-vararg(ctx: FContext, k: CString, kt: Type, f: Fragment): FContext = (
   let binding = ctx.lookup-soft(k, kt, mk-eof());
   binding.vararg = cons( close(f), binding.vararg );
   binding.type = kt;
   ctx = ctx.bind(k, kt, binding);
   ctx
);

let union(ctx: FContext, tctx: Maybe<TypeContext>): FContext = (
   let r = ctx;
   for TypeContextRow{ k=key } in tctx.get-or(mk-tctx()).tctx {
      r = r.bind( k, ta, mk-fragment() );
   };
   r
);

let .bind(ctx: FContext, k: CString, kt: Type, f: Fragment): FContext = (
   FCtxBind( close(ctx), k, denormalize(kt), f )
);


let .lookup(ctx: FContext, k: CString, kt: Type, sloc: AST): Fragment = (
   ctx.lookup( k, kt, sloc, true )
);

let .lookup-soft(ctx: FContext, k: CString, kt: Type, sloc: AST): Fragment = (
   ctx.lookup( k, kt, sloc, false )
);

# TODO: unify lookup and lookups logic, with common logical elements isolated and explanation of algorithm

let .lookup(ctx: FContext, k: CString, kt: Type, sloc: AST, hard: Bool): Fragment = (
   let original-ctx = ctx;
   let found = ta;
   let r = mk-fragment();
   kt = denormalize-strong(kt);
   while non-zero(ctx) { match ctx {
      FCtxBind { remainder=remainder, ctx-k=k, ctx-kt=kt, ctx-kv=kv } => (
         if k==ctx-k {
            if ctx-kt.is-arrow and not(kt.is-t(c"Any",0)) {
               if kt==ta or can-unify( ctx-kt.domain, kt ) or can-unify(ctx-kt.domain, kt.domain) {
                  if non-zero(found) {
                     if can-unify(found, ctx-kt.domain) {
                        r = ctx-kv;
                        found = ctx-kt.domain;
                     }
                  } else {
                     r = ctx-kv;
                     found = ctx-kt.domain;
                  }
               };
               ctx = remainder;
            } else {
               r = ctx-kv;
               found = t0(c"LocalVariable");
               ctx = FCtxEOF();
            }
         } else { ctx = remainder; }
      );
   }};
   if not(non-zero(found)) and hard {
      print("Context::lookup \{k} : \{kt}\nCandidates:\n");
      while non-zero(original-ctx) { match original-ctx {
         FCtxBind { remainder=remainder, ctx-k2=k, ctx-kt=kt } => (
            if k==ctx-k2 { print("\{k} : \{ctx-kt}\n"); };
            original-ctx = remainder;
         );
      }};
      print("Context::lookup Could Not Find Symbol at \{sloc.location}\n");
      exit(1);
   };
   r
);

type Fragment = { term: AST, keyvals: OneOwnedData<List<Tuple<CString,S>>>[], type: Type, context: OneOwnedData<FContext>[], vararg: List<OneOwnedData<Fragment>[]> };

type FContext zero FCtxEOF = FCtxEOF | FCtxBind{ remainder:OneOwnedData<FContext>[] , k:CString , kt:Type , kv:Fragment };

let .get(e: Fragment, k: CString): S = (
   let r = SNil();
   let found = false;
   for kv in open(e.keyvals) {
      if not(found) and kv.first==k { r = kv.second; found = true; };
   };
   r
);

let .set(e: Fragment, k: CString, v: S): Fragment = (
   Fragment (
      e.term,
      close(LCons( Tuple(k, v), e.keyvals )),
      e.type, e.context, e.vararg
   )
);

let global-ctx = FCtxEOF;

let mk-expression(val: CString): Fragment = (
   mk-fragment().set(c"expression", SAtom(val.into(type(String))))
);

let mk-expression(val: S): Fragment = (
   mk-fragment().set(c"expression", val)
);


let mk-fctx(): FContext = FCtxEOF;

let mk-fragment(): Fragment = (
   Fragment (
      mk-eof(), close([] : List<Tuple<CString,S>>),
      ta, close(mk-fctx()), ([] : List<OneOwnedData<Fragment>[]>)
   )
);

let non-zero(f: Fragment): Bool = (
   non-zero(open(f.keyvals))
);

