
typed macro $"assert"(c: lazy): lazy = (
   if not c then fail(c"Assertion Failed At ", macro::location(c));
);

typed macro macro::let(lhs: lazy, rhs: lazy): lazy = (
   (fn(lhs) = ()) (rhs)
);

typed macro macro::set(lhs: lazy, rhs: lazy): lazy = (
   mov(rhs, lhs)
);

typed macro macro::set(base index: macro::lhs-index, rhs: lazy): lazy = (
   $"set[]"( base, index, rhs )
);

typed macro macro::set(base field: macro::lhs-field, rhs: lazy): lazy = (
   macro::concat($"set.", field) (base, rhs)
);

typed macro macro::lhs-as-rhs(v: macro::variable): lazy = (
   v
);

typed macro macro::lhs-as-rhs(base: macro::lhs-address-of): lazy = (
   &v
);

typed macro macro::lhs-address-of(base: lazy): lazy = (
   base
);

typed macro macro::lhs-field(base: lazy, field: lazy): lazy = (
   base; field
);

typed macro macro::lhs-as-rhs(base field: macro::lhs-index): lazy = (
   macro::concat(l".", field)(base)
);

typed macro macro::lhs-index(base: lazy, index: lazy): lazy = (
   base; index
);

typed macro macro::lhs-index(base field: macro::lhs-field, index: lazy): lazy = (
   macro::concat($".", field)(base); index
);

typed macro macro::while(cond: Bool, body: lazy): lazy = (
   primitive::while( cond, body as Nil )
);

typed macro macro::for(item: lazy, iterable: List<?>, loop: lazy): lazy = (
   let uuid(iter-term) = iterable;
   while non-zero(uuid(iter-term)) {
      match head(uuid(iter-term)) {
         item => loop;
      };
      uuid(iter-term) = tail(uuid(iter-term));
   };
);

typed macro macro::for(item: lazy, iterable: Vector<?>, loop: lazy): lazy = (
   let uuid(iter-term) = iterable;
   let uuid(iter-i) = 0_sz;
   while uuid(iter-i) < uuid(iter-term).length {
      match uuid(iter-term)[uuid(iter-i)] {
         item => loop;
      };
      uuid(iter-i) = uuid(iter-i) + 1;
   };
);

typed macro macro::match(t: lazy, ps: lazy): lazy = (scope(
   let uuid(term) = open(t);
   macro::match-pats( uuid(term), ps, fail(c"Pattern Match Failure ", macro::location(t)) );
));

typed macro macro::match(t: macro::bind-raw, ps: lazy): lazy = (scope(
   let uuid(term) = t;
   macro::match-pats( uuid(term), ps, fail(c"Pattern Match Failure ", macro::location(t)) );
));

typed macro macro::match(f t: macro::bind-raw-field, ps: lazy): lazy = (scope(
   let uuid(term) = f($"raw"(t));
   macro:: match-pats( uuid(term), ps, fail(c"Pattern Match Failure ", macro::location(t)) );
));

typed macro macro::match-pats(term: lazy, cases: macro::pats-none, remainder: lazy): lazy = (
   remainder
);

typed macro macro::match-pats(term: lazy, ps lhs rhs: macro::pats-some, remainder: lazy): lazy = (
   macro::match-pats(term, ps, scope($"if"(macro::match-pats-arm(term,lhs))(rhs)(remainder)));
);

typed macro macro::pats-some(ps: lazy, lhs: lazy, rhs: lazy): lazy = (
   ps; lhs; rhs
);

typed macro macro::pats-none(ignore: lazy): lazy = (
   ()
);

typed macro macro::match-pats-arm(term: lazy, v: macro::variable): lazy = (
   macro::let(v, term); branchtrue()
);

typed macro macro::match-pats-arm(term: lazy, v pat: macro::match-lhs-binding): lazy = (
   macro::let(v, term); match-pats-arm(v, pat)
);

typed macro macro::match-pats-arm(term: lazy, ignore: macro::underscore): lazy = (
   branchtrue()
);

typed macro macro::match-pats-arm(term: lazy, x rest: macro::lhs-head): lazy = (
   macro::let(uuid(v), term);
   $"if"(uuid(v).has-head)
      ($"if"(macro::match-pats-arm(head(uuid(v)),x))
         ( macro::match-pats-arm(tail(uuid(v)),rest) )
         (branchfalse())
      )
      (branchfalse())
);

typed macro macro::match-pats-arm(term: lazy, c: macro::constant): lazy = (
   macro::let(uuid(v), term); uuid(v)==c
);

typed macro macro::lhs-tagged(tag-guard: lazy, fields-guard: lazy): lazy = (
   tag-guard; fields-guard;
);

typed macro macro::lhs-fields-field(field-key: macro::variable, pat: lazy): lazy = (
   field-key; pat;
);

typed macro macro::lhs-bind(bind-key: macro::variable, pat: lazy): lazy = (
   bind-key; pat;
);

typed macro macro::lhs-fields(prefix: lazy, fields: lazy): lazy = (
   prefix; fields;
);

typed macro macro::lhs-fields-with-term(term: lazy, prefix last: macro::lhs-fields): Bool = (
   $"if"(macro::lhs-fields-with-term(term, prefix))
        (macro::lhs-fields-with-term(term, last))
        (branchfalse())
);

typed macro macro::lhs-head(x: head, xs: tail): lazy = (
   x; xs;
);

typed macro macro::match-pats-arm(term: lazy, case: macro::literal<MACRO::LHS-LIST-SENTINEL,_>): lazy = (
   true
);

typed macro macro::lhs-fields-with-term(term: lazy, case: macro::literal<MACRO::LHS-LIST-SENTINEL,_>): lazy = (
   true
);

typed macro macro::lhs-fields-with-term(term: lazy, v: macro::variable): Bool = (
   let v = term; true
);

typed macro macro::lhs-fields-with-term(term: lazy, x rest: macro::lhs-head): Bool = (
   macro::let(uuid(v), term);
   $"if"(uuid(v).has-head)
      ($"if"(macro::match-pats-arm(head(uuid(v)),x))
         ( macro::match-pats-arm(tail(uuid(v)),rest) )
         (branchfalse())
      )
      (branchfalse())
);

typed macro macro::lhs-fields-with-term(term: lazy, bind pat: macro::lhs-bind): Bool = (
   let bind = term;
   macro::lhs-fields-with-term(bind, pat)
);

typed macro macro::lhs-fields-with-term(term: lazy, field-key pat: macro::lhs-fields-field): Bool = (
   let uuid(x) = open(field-key(term));
   macro::lhs-fields-with-term(uuid(x), pat)
);

typed macro macro::lhs-fields-with-term(term: lazy, ignore: macro::nil): Bool = (
   true
);

typed macro macro::lhs-fields-with-term(term: lazy, c: macro::constant): Bool = (
   term == c
);

typed macro macro::lhs-fields-with-term(term: lazy, ignore: macro::underscore): Bool = (
   true
);

typed macro macro::lhs-fields-with-term(term: lazy, tag-guard fields-guard: macro::lhs-tagged): Bool = (
   macro::lhs-tagged-with-term(term, tag-guard, fields-guard)
);

typed macro macro::lhs-tagged-with-term(term: lazy, tag-name tag-ordinal tag-type: macro::tag, fields: lazy): Bool = (
   $"if"(term.discriminator-case-tag==(term as tag-type).discriminator-case-tag)
        (macro::lhs-fields-with-term((term as tag-type), fields))
        (branchfalse())
);

typed macro macro::lhs-tagged-with-term(term: lazy, tag-guard: macro::nil, prefix pat: macro::lhs-fields): Bool = (
   macro::lhs-fields-with-term(term, prefix, pat)
);

typed macro macro::lhs-tagged-with-term(term: lazy, tag-name tag-ordinal tag-type: macro::tag, fields-guard: macro::nil): Bool = (
   term.discriminator-case-tag==(term as tag-type).discriminator-case-tag
);

typed macro macro::match-pats-arm(term: lazy, tag-guard fields-guard: macro::lhs-tagged): lazy = (
   macro::lhs-tagged-with-term(term, tag-guard, fields-guard);
);

typed macro macro::match-pats-arm-with-term(term: lazy, bind prefix: macro::lhs-bind, suffix: lazy): Bool = (
   let uuid(v) = term;
   let uuid(s) = uuid(v).remove-prefix(prefix);
   let uuid(p) = uuid(v).get-prefix(prefix);
   $"if"(uuid(p).is-some and uuid(s).is-some)
        (macro::let(b, uuid(p).get-or-panic); macro::match-pats-arm(uuid(s).get-or-panic,suffix))
        (branchfalse())
);

typed macro macro::match-pats-arm-with-term(term: lazy, prefix: lazy, bind suffix: macro::lhs-bind): Bool = (
   let uuid(v) = term;
   let uuid(s) = uuid(v).remove-suffix(suffix);
   let uuid(p) = uuid(v).get-suffix(suffix);
   $"if"(uuid(p).is-some and uuid(s).is-some)
        (macro::let(b, uuid(p).get-or-panic); macro::match-pats-arm(uuid(s).get-or-panic,prefix))
        (branchfalse())
);

typed macro macro::match-pats-arm-with-term(term: lazy, pat: macro::constant, rest: lazy): Bool = (
   macro::let(uuid(v), term);
   macro::let(uuid(p), uuid(v).remove-prefix(pat));
   $"if"(uuid(p).is-some)
        (macro::match-pats-arm(uuid(p).get-or-panic, rest))
        (branchfalse())
);

typed macro macro::match-pats-arm-with-term(term: lazy, rest: lazy, pat: macro::constant): Bool = (
   macro::let(uuid(v), term);
   macro::let(uuid(p), uuid(v).remove-suffix(pat));
   $"if"(uuid(p).is-some)
        (macro::match-pats-arm(uuid(p).get-or-panic, rest))
        (branchfalse())
);

typed macro macro::lhs-prefix-or-suffix(prefix: lazy, suffix: lazy): Bool = (prefix; suffix);

typed macro macro::match-pats-arm(term: lazy, prefix suffix: macro::lhs-prefix-or-suffix): Bool = (
   macro::match-pats-arm-with-term(term, prefix, suffix);
);

