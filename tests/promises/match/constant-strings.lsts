
import lib/core/dev-bedrock.lsts;

let argv = mk-vector(type(CString)).push(c"--v23").push(c"--c");
let argi = 0_sz;

while argi < argv.length {
   match argv[argi] {
      c"--typecheck" => ();
      c"--parse" => ();
      c"--preprocess" => ();
      c"--compile" => ();
      c"--v0" => ();
      c"--v1" => ();
      c"--v2" => ();
      c"--v23" => ();
      c"--v3" => ();
      c"--highlight" => ();
      c"--tokens" => ();
      c"--stripdebug" => ();
      c"--showalloc" => ();
      c"--showallocgen" => ();
      c"--showastcount" => ();
      c"--profile-ast" => ();
      c"-o" => ();
      fp1 => fail(c"STOP!");
   };
   argi = argi + 1;
};
