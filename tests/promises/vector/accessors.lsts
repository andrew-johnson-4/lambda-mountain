
import lib/core/dev-bedrock.lsts;

assert( mk-vector(type(U8)).push(1).push(2).push(3).nth(0) == Some(1) );
assert( mk-vector(type(U8)).push(1).push(2).push(3).nth(1) == Some(2) );
assert( mk-vector(type(U8)).push(1).push(2).push(3).nth(2) == Some(3) );
assert( safe-alloc-block-count == 0 );

assert( not(mk-vector(type(U8)).has-head) );
assert( mk-vector(type(U8)).push(1).has-head );
assert( mk-vector(type(U8)).push(1).push(2).has-head );
assert( mk-vector(type(U8)).push(1).push(2).push(3).has-head );
assert( safe-alloc-block-count == 0 );

assert( head(mk-vector(type(U8)).push(1)) == 1 );
assert( head(mk-vector(type(U8)).push(1).push(2)) == 1 );
assert( head(mk-vector(type(U8)).push(1).push(2).push(3)) == 1 );
assert( safe-alloc-block-count == 0 );

assert( mk-vector(type(U8)).push(1).push(2).push(3)[1_u64:][0] == 2 );
assert( mk-vector(type(U8)).push(1).push(2).push(3)[1_u64:][1] == 3 );
assert( mk-vector(type(U8)).push(1).push(2).push(3)[2_u64:][0] == 3 );
assert( safe-alloc-block-count == 0 );

assert( mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:][1_u64:][0] == 2 );
assert( mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:][1_u64:][1] == 3 );
assert( mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:][2_u64:][0] == 3 );
assert( safe-alloc-block-count == 0 );

assert( tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:])[0] == 2 );
assert( tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:])[1] == 3 );
assert( tail(tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:]))[0] == 3 );
assert( safe-alloc-block-count == 0 );

assert( head(tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:])) == 2 );
assert( head(tail(tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:]))) == 3 );
assert( head(tail(tail(mk-vector(type(U8)).push(0).push(1).push(2).push(3)[1_u64:]))) == 3 );
assert( safe-alloc-block-count == 0 );

assert( not(non-zero(mk-vector(type(U8)))) );
assert( non-zero(mk-vector(type(U8)).push(1)) );
assert( not(non-zero(tail(mk-vector(type(U8)).push(1)))) );
assert( non-zero(tail(mk-vector(type(U8)).push(1).push(2))) );
assert( safe-alloc-block-count == 0 );
