
import lib/std/minimal.lsts;

let table = mk-hashtable(type(String), type(U64));

print("\{21}");

print("Hashtable 1\n");

let ti = 0_u64;
while ti < 5000 {
   let k = "\{ti}";
   print("Hashtable \{ti} \{k.data as U64}\n");
   table = table.bind(k, ti);
   ti = ti + 1;
};

ti = 0_u64;
while ti < 5000 {
   print("Hashtable \{ti}\n");
   assert(table.lookup("\{ti}", 0_u64) == ti);
   ti = ti + 1;
};
