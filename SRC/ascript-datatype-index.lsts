
# All datatypes must be registered as such here

let datatype-index = mk-set(type((CString,U64)));

let .is-datatype(tt: Type): Bool = (
   match tt {
      TAnd{conjugate=conjugate} => (
         let found = false;
         for c in conjugate {
            found = found or c.is-datatype;
         };
         found
      );
      _ => (
         let gta = tt.ground-tag-and-arity;
         datatype-index.has(gta)
      );
   }
);
