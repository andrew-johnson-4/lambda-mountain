
let global-symbol-registry = mk-set(type((CString,Type)));

let mark-global-as-seen(name: CString, tt: Type, tlt: Type): Nil = (
   if global-is-seen(name,tt) and not(tlt.is-t(c"FFI",0)) then fail("Duplicate Global Symbol \{name} : \{tt}");
   global-symbol-registry = global-symbol-registry.bind((name,tt));
);

let global-is-seen(name: CString, tt: Type): Bool = global-symbol-registry.has((name,tt));
