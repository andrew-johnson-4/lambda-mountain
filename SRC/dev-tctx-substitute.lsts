
let .substitute(tctx: TypeContext?, tt: Vector<Type>): Vector<Type> = (
   let next = mk-vector(type(Type));
   for t in tt {
      next = next.push(tctx.substitute(tctx.substitute(t)))
   };
   next
);

let .substitute(tctx: TypeContext?, tt: Type): Type = (
   match tt {
      TAnd{conjugate=conjugate} => (
         let result = mk-vector(type(Type), 0);
         for vector c in conjugate {
            match tctx.substitute(c) {
               TAnd{rconjugate=conjugate} => for vector rc in rconjugate { result = result.push(rc) };
               TAny{} => ();
               rc => ( result = result.push(rc); () );
            }
         };
         if result.length==0 then ta
         else if result.length==1 then result[0]
         else tand(result)
      );
      TGround{tag=tag,parameters=parameters} => TGround(tag,tctx.substitute(parameters));
      TVar{name=name} => (
         let tn = tctx.lookup(name).direct-type;
         if non-zero(tn) then tn else tt;
      );
      _ => tt;
   }
);
